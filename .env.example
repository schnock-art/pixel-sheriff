WEB_PORT=3010
API_PORT=8010
POSTGRES_PORT=5433
REDIS_PORT=6380
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=pixel_sheriff
REDIS_URL=redis://redis:6379/0
JOB_QUEUE_KEY=pixel_sheriff:train_jobs:v1
TRAINER_POLL_SECONDS=5
TRAINER_GPUS=all
TRAINER_PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cu129
# Optional prebuilt image containing torch/torchvision + CUDA wheels.
# Example: pixel-sheriff/trainer-base:cu129
TRAINER_BASE_IMAGE=python:3.11-slim
# Tag used by `docker compose --profile build-tools build trainer-base`.
TRAINER_BASE_TAG=pixel-sheriff/trainer-base:cu129
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
# Used for direct local (non-docker-compose) runs. In docker compose, STORAGE_ROOT is pinned to /app/data.
STORAGE_ROOT=./data
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3010,http://127.0.0.1:3010
